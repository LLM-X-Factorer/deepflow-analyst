# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# --- OpenRouter ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model used by the app. W11 (LLMOps) replaces this with a ModelRouter.
# deepseek/deepseek-v3.2 chosen because: (a) region-robust (no provider ToS
# rejection), (b) cheapest on OpenRouter for this tier, (c) beat minimax-m2.7
# on our golden dataset (57% vs 43% accuracy). Override freely for experiments.
DEFAULT_MODEL=deepseek/deepseek-v3.2

# --- Few-shot RAG (X) ---
# RAG_ENABLED=true injects top-K similar solved (question, sql) pairs from
# src/deepflow_analyst/fewshot/examples.jsonl into the Writer system prompt.
# The bank is independent of the golden dataset (tests enforce no overlap).
# Disabling with RAG_ENABLED=false reverts to zero-shot — useful for A/B
# comparison or cost trimming.
RAG_ENABLED=true
RAG_TOP_K=3

# --- Stability sampling (Z) ---
# SAMPLE_SIZE > 1 turns on self-consistency majority voting: the Writer is
# sampled N times at SAMPLE_TEMPERATURE, each candidate is reviewed and
# executed, and the SQL whose result set appears most often wins. This
# absorbs OpenRouter's ±5pp provider routing noise. N=1 is the baseline
# (zero-cost, deterministic). N=3 is a sweet spot for local/CI.
SAMPLE_SIZE=1
SAMPLE_TEMPERATURE=0.5

# --- Langfuse tracing (W11 · optional) ---
# 任何一个 key 为空 → graceful no-op（保持 v0.4 行为，不影响 eval / CI）。
# 配齐三个 → 每次 LLM 调用上报 Langfuse，UI 里能按角色
# (writer / reviewer / intent / insight) 分组看 trace。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- ModelRouter (W11 · per-role model overrides) ---
# 留空 → 所有 role 都用 DEFAULT_MODEL；任一项设值就只给那个 role 换 model。
# 示例：INSIGHT_MODEL=moonshotai/kimi-k2 让解读话术更自然。必须先用
# `deepflow-eval` 验证新 model 不降低 accuracy，才能改 commit。
WRITER_MODEL=
REVIEWER_MODEL=
INTENT_MODEL=
INSIGHT_MODEL=

# --- Database ---
# For local host-side development (not inside docker-compose).
# Note: docker-compose maps postgres to host port 55433 to avoid conflicts.
DATABASE_URL=postgresql+psycopg://deepflow:deepflow@localhost:55433/deepflow

# --- App ---
APP_ENV=dev
APP_PORT=8000
