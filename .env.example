# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# --- OpenRouter ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model used by the app. W11 (LLMOps) replaces this with a ModelRouter.
# deepseek/deepseek-v3.2 chosen because: (a) region-robust (no provider ToS
# rejection), (b) cheapest on OpenRouter for this tier, (c) beat minimax-m2.7
# on our golden dataset (57% vs 43% accuracy). Override freely for experiments.
DEFAULT_MODEL=deepseek/deepseek-v3.2

# --- Database ---
# For local host-side development (not inside docker-compose).
# Note: docker-compose maps postgres to host port 55433 to avoid conflicts.
DATABASE_URL=postgresql+psycopg://deepflow:deepflow@localhost:55433/deepflow

# --- App ---
APP_ENV=dev
APP_PORT=8000
